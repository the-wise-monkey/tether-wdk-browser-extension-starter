{
  "manifest_version": 3,
  "name": "Tether WDK Browser Wallet Starter",
  "short_name": "WDK Wallet",
  "version": "0.1.0",
  "description": "Reference Chrome/Brave extension wallet starter built with Tether WDK.",
  "permissions": ["storage", "alarms", "activeTab", "clipboardRead", "clipboardWrite", "sidePanel"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src 'self' https: wss:"
  },
  "web_accessible_resources": [
    {
      "resources": ["inject.js", "icon.svg"],
      "matches": ["<all_urls>"],
      "use_dynamic_url": true
    }
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["inject-shim.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Open WDK Wallet",
    "default_icon": "icon.svg"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "icons": {
    "16": "icon.svg",
    "48": "icon.svg",
    "128": "icon.svg"
  }
}
